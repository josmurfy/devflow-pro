{
  "name": "devflow-pro",
  "displayName": "DevFlow Pro",
  "description": "Debug Logger Manager for OpenCart 4.x — manage bug tickets, Copilot integration",
  "version": "2.0.8",
  "publisher": "josmurfy",
  "icon": "resources/icon.jpg",
  "repository": {
    "type": "git",
    "url": "https://github.com/josmurfy/devflow-pro"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Debuggers"
  ],
  "keywords": [
    "bug",
    "debug",
    "opencart",
    "copilot",
    "ai",
    "tickets",
    "debug-logger"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devflow.checkForUpdates",
        "title": "Check for Updates",
        "category": "DevFlow",
        "icon": "$(cloud-download)"
      },
      {
        "command": "devflow.rollbackVersion",
        "title": "Rollback to Previous Version",
        "category": "DevFlow"
      },
      {
        "command": "devflow.switchUpdateChannel",
        "title": "Switch Update Channel (Stable/Beta)",
        "category": "DevFlow"
      },
      {
        "command": "devflow.showOutput",
        "title": "Show Output Log",
        "category": "DevFlow"
      },
      {
        "command": "debugLogger.configure",
        "title": "Configure Database",
        "category": "Debug Logger",
        "icon": "$(gear)"
      },
      {
        "command": "debugLogger.refresh",
        "title": "Refresh Tickets",
        "category": "Debug Logger",
        "icon": "$(refresh)"
      },
      {
        "command": "debugLogger.showTicket",
        "title": "Show Ticket Details",
        "category": "Debug Logger"
      },
      {
        "command": "debugLogger.sendToCopilot",
        "title": "Send to Copilot",
        "category": "Debug Logger",
        "icon": "$(hubot)"
      },
      {
        "command": "debugLogger.closeTicket",
        "title": "Close Ticket",
        "category": "Debug Logger",
        "icon": "$(check)"
      },
      {
        "command": "debugLogger.reopenTicket",
        "title": "Reopen Ticket",
        "category": "Debug Logger"
      },
      {
        "command": "debugLogger.deleteTicket",
        "title": "Delete Ticket",
        "category": "Debug Logger",
        "icon": "$(trash)"
      },
      {
        "command": "debugLogger.openRelatedFiles",
        "title": "Open Related Files",
        "category": "Debug Logger",
        "icon": "$(file-code)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devflow",
          "title": "DevFlow Pro",
          "icon": "$(extensions)"
        },
        {
          "id": "debugLogger",
          "title": "Debug Logger",
          "icon": "$(bug)"
        }
      ]
    },
    "views": {
      "devflow": [
        {
          "id": "devflow.statusView",
          "name": "Status",
          "type": "tree"
        }
      ],
      "debugLogger": [
        {
          "id": "debugLogger.ticketList",
          "name": "Tickets",
          "type": "tree"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "devflow.checkForUpdates",
          "when": "view == devflow.statusView",
          "group": "navigation"
        },
        {
          "command": "debugLogger.refresh",
          "when": "view == debugLogger.ticketList",
          "group": "navigation@1"
        },
        {
          "command": "debugLogger.configure",
          "when": "view == debugLogger.ticketList",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "debugLogger.sendToCopilot",
          "when": "view == debugLogger.ticketList && viewItem =~ /ticket/",
          "group": "inline@1"
        },
        {
          "command": "debugLogger.openRelatedFiles",
          "when": "view == debugLogger.ticketList && viewItem =~ /ticket/",
          "group": "1_actions@1"
        },
        {
          "command": "debugLogger.closeTicket",
          "when": "view == debugLogger.ticketList && viewItem == ticket-open",
          "group": "1_actions@2"
        },
        {
          "command": "debugLogger.reopenTicket",
          "when": "view == debugLogger.ticketList && viewItem == ticket-closed",
          "group": "1_actions@2"
        },
        {
          "command": "debugLogger.deleteTicket",
          "when": "view == debugLogger.ticketList && viewItem =~ /ticket/",
          "group": "2_danger@1"
        }
      ]
    },
    "configuration": {
      "title": "DevFlow Pro",
      "properties": {
        "devflow.updates.autoCheck": {
          "type": "boolean",
          "default": true,
          "description": "Automatically check for updates on startup"
        },
        "devflow.updates.channel": {
          "type": "string",
          "enum": [
            "stable",
            "beta"
          ],
          "default": "stable",
          "description": "Update channel to use (stable = production, beta = early access)"
        },
        "devflow.updates.autoDownload": {
          "type": "boolean",
          "default": false,
          "description": "Automatically download updates when available (requires manual install)"
        },
        "devflow.updates.autoInstall": {
          "type": "boolean",
          "default": false,
          "description": "Automatically install updates without confirmation (not recommended)"
        },
        "devflow.updates.checkInterval": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 168,
          "description": "Hours between automatic update checks"
        },
        "devflow.updates.serverUrl": {
          "type": "string",
          "default": "https://phoenixliquidation.ca/devflow/updates",
          "description": "Custom update server URL (advanced users)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node",
    "pretest": "npm run compile",
    "test": "vscode-test",
    "package": "vsce package --no-dependencies",
    "build": "npm run bundle && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "mysql2": "^3.21.0"
  }
}
